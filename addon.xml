<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.streamvault"
       name="StreamVault"
       version="1.0.0"
       provider-name="mulen">

    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.requests" version="2.9.1"/>
        <import addon="script.module.websocket-client" version="0.58.0" optional="true"/>
        <import addon="service.upnext" version="1.0.0" optional="true"/>
    </requires>

    <!-- Video plugin -->
    <extension point="xbmc.python.pluginsource" library="main.py">
        <provides>video</provides>
    </extension>

    <!-- Background service -->
    <extension point="xbmc.python.script" library="service.py">
        <provides>executable</provides>
    </extension>

    <extension point="xbmc.addon.metadata">
        <platform>all</platform>
        <language>cs sk en</language>
        <license>GPL v2</license>
        <description lang="cs_cz">
            StreamVault – stream-cinema.online katalog s podporou kra.sk, WebShare, debrid služeb a uložením do knihovny.
        </description>
        <description lang="en_gb">
            StreamVault – stream-cinema.online catalog with kra.sk, WebShare, debrid services and library export support.
        </description>
        <reuselanguageinvoker>true</reuselanguageinvoker>
    </extension>

</addon>
