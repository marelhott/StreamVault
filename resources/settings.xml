<?xml version="1.0" encoding="UTF-8"?>
<settings>

    <!-- kra.sk -->
    <category label="kra.sk">
        <setting type="lsep" label="Prihlaseni"/>
        <setting type="text"   label="Uzivatelske jmeno" id="kraska.user"      default="mulenmara"/>
        <setting type="text"   label="Heslo"             id="kraska.pass"      default="Maho1505" option="hidden"/>
        <setting type="text"   label="Dni predplatneho"  id="kraska.days.left" default="" enable="false"/>
        <setting type="sep"/>
        <setting type="lsep" label="Pokrocile"/>
        <setting type="text"   label="Preferovany server (prazdne = auto)" id="stream.adv.speedtest.best_server" default=""/>
        <setting type="text" id="kraska.token"              default="" visible="false"/>
        <setting type="text" id="kraska.chsum"              default="" visible="false"/>
        <setting type="text" id="system.auth_token"         default="" visible="false"/>
        <setting type="text" id="system.auth_token_updated" default="" visible="false"/>
        <setting type="text" id="system.ver"                default="" visible="false"/>
        <setting type="text" id="system.changelog"          default="" visible="false"/>
        <setting type="text" id="plugin.uuid"               default="" visible="false"/>
    </category>

    <!-- WebShare.cz -->
    <category label="WebShare.cz">
        <setting type="bool"   label="Pouzit WebShare jako zalozu" id="webshare.enabled" default="true"/>
        <setting type="text"   label="Uzivatelske jmeno" id="webshare.user" default="oretlogin"  enable="eq(-1,true)"/>
        <setting type="text"   label="Heslo"             id="webshare.pass" default="Maho1505"   enable="eq(-2,true)" option="hidden"/>
        <setting type="text" id="webshare.wst" default="" visible="false"/>
    </category>

    <!-- Prehravani -->
    <category label="Prehravani">
        <setting type="bool"   label="Automaticky vybrat nejlepsi stream"  id="stream.auto_pick"         default="true"/>
        <setting type="select" label="Preferovana kvalita"                 id="stream.preferred_quality" values="4K|1080p|720p|480p" default="1080p"/>
        <setting type="select" label="Preferovany jazyk"                   id="stream.preferred_lang"    values="cs|sk|en"           default="cs"/>
        <setting type="bool"   label="Zobrazit HDR streamy"      id="stream.show.hdr" default="true"/>
        <setting type="bool"   label="Zobrazit Dolby Vision"     id="stream.show.dv"  default="true"/>
        <setting type="bool"   label="Preferovat dabing"         id="stream.dubed"    default="false"/>
        <setting type="bool"   label="Titulkovane verze"         id="stream.dubed.titles" default="false"/>
        <setting type="bool"   label="Vyloucit HDR"              id="stream.exclude.hdr"         default="false"/>
        <setting type="bool"   label="Vyloucit Dolby Vision"     id="stream.exclude.dolbyvision"  default="false"/>
    </category>

    <!-- Zahranicni obsah -->
    <category label="Zahranicni obsah">
        <setting type="bool"   label="Zapnout zahranicni obsah (debrid)" id="intl.enabled" default="true"/>
        <setting type="select" label="Debrid sluzba"
                               id="debrid.service"
                               values="Vypnuto|Real-Debrid|AllDebrid|Premiumize|TorBox"
                               default="Real-Debrid"/>
        <setting type="text"   label="API klic debrid"
                               id="debrid.api_key"
                               default="VLGVHWAO64GBQIWWZUVV5XE2F3J7ZK3SEEZDIOJFOTOBCUSMYA4Q"
                               option="hidden"/>
    </category>

    <!-- Metadata -->
    <category label="Metadata (TMDB)">
        <setting type="bool"   label="Obohacovat metadata z TMDB" id="tmdb.enabled"  default="true"/>
        <setting type="text"   label="TMDB API klic (volitelny)"  id="tmdb.api_key"  default=""/>
        <setting type="select" label="Jazyk metadat"              id="tmdb.language" values="cs|sk|en" default="cs"/>
    </category>

    <!-- Knihovna -->
    <category label="Knihovna">
        <setting type="folder" label="Slozka pro filmy"   id="movie.library.path"  source=""/>
        <setting type="action" label="Test filmove knihovny"
                               action="RunPlugin(plugin://plugin.video.streamvault?action=test_movie_library_path)"
                               enable="!eq(-1,)"/>
        <setting type="folder" label="Slozka pro serialy" id="tvshow.library.path" source=""/>
        <setting type="action" label="Test serialove knihovny"
                               action="RunPlugin(plugin://plugin.video.streamvault?action=test_tvshow_library_path)"
                               enable="!eq(-1,)"/>
        <setting type="select" label="Rezim metadat"
                               id="library.metadata.mode"
                               values="Pouze STRM|STRM + NFO"
                               default="STRM + NFO"/>
        <setting type="select" label="Aktualizovat knihovnu po exportu"
                               id="library.update.mode"
                               values="Ne|Ano"
                               default="Ano"/>
    </category>

    <!-- Rodicovska kontrola -->
    <category label="Rodicovska kontrola">
        <setting type="bool"   label="Zapnout rodicovskou kontrolu" id="parental.control.enabled" default="false"/>
        <setting type="select" label="Maximalni hodnoceni"
                               id="parental.control.rating"
                               values="Bez omezeni|6+|12+|15+|18+"
                               default="Bez omezeni"
                               enable="eq(-1,true)"/>
        <setting type="slider" label="Aktivni od hodiny" id="parental.control.start" default="20" range="0,1,23" enable="eq(-2,true)"/>
        <setting type="slider" label="Aktivni do hodiny" id="parental.control.end"   default="22" range="0,1,23" enable="eq(-3,true)"/>
        <setting type="bool"   label="Jen dabing pri rodicovske kontrole" id="parental.control.dubed" default="true" enable="eq(-4,true)"/>
    </category>

    <!-- Vzhled -->
    <category label="Vzhled">
        <setting type="bool" label="Zobrazit zanr v titulku" id="plugin.show.genre"    default="false"/>
        <setting type="bool" label="Zobrazit stare menu"     id="plugin.show.old.menu" default="false"/>
    </category>

    <!-- Ladeni -->
    <category label="Ladeni">
        <setting type="bool"   label="Zapnout debug log" id="plugin.debug" default="false"/>
        <setting type="action" label="Odeslat debug log"
                               action="RunPlugin(plugin://plugin.video.streamvault?action=debug)"/>
    </category>

</settings>
